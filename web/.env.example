# ───────────── Banco ─────────────
# Em prod: Vercel Postgres injeta isso automático ao criar o DB no dashboard.
# Em dev local: criar Postgres free no neon.tech e colar a connection string.
DATABASE_URL="postgresql://user:pass@host:5432/dbname?sslmode=require"

# ───────────── Auth ─────────────
# Gere uma forte: node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
JWT_SECRET=""

# ───────────── Seed (admin) ─────────────
# Token pra acessar /api/admin/seed e popular dados de demo em prod.
# Gere: node -e "console.log(require('crypto').randomBytes(24).toString('base64url'))"
SEED_TOKEN=""

# ───────────── Cron worker ─────────────
# Token pra autenticar /api/cron/tick (chamado por cron-job.org a cada 1min).
# Gere: node -e "console.log(require('crypto').randomBytes(24).toString('base64url'))"
CRON_TOKEN=""

# ───────────── Z-API ─────────────
# Tokens da Z-API:
#   - INSTANCE_ID e TOKEN: específicos da instância (cada chip conectado)
#   - CLIENT_TOKEN: da conta inteira (Account Token, exigido em planos Plus)
ZAPI_BASE_URL="https://api.z-api.io"
ZAPI_INSTANCE_ID=""
ZAPI_TOKEN=""
ZAPI_CLIENT_TOKEN=""
